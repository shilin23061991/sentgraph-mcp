{
  "description": "Хуки памяти Sentgraph: рано подгружают контекст Zep и часто сохраняют ходы беседы.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentgraph-mcp hook SessionStart",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentgraph-mcp hook UserPromptSubmit",
            "timeout": 20
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentgraph-mcp hook PreCompact",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentgraph-mcp hook Stop",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentgraph-mcp hook SessionEnd",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
