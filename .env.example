# Required identity keys. Copy this file to .env.local (gitignored) and fill in.
# sentgraph-mcp loads .env.local automatically (non-override: real env wins) and
# refuses to start without a project .env.local (guards against global installs).
ZEP_API_KEY=
ZEP_USER_ID=
SENTGRAPH_PROJECT_ID=

# Hooks: read/write frequently by default.
SENTGRAPH_INJECT_EVERY_PROMPT=true
SENTGRAPH_PROJECT_AUTOCAPTURE=true
SENTGRAPH_CAPTURE_TOOLS=false
SENTGRAPH_CONTEXT_TOKEN_BUDGET=2000
